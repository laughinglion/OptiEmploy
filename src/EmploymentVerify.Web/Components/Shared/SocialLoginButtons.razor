@using Microsoft.Extensions.Options
@using EmploymentVerify.Web.Authentication
@inject IOptions<GoogleAuthSettings> GoogleSettings
@inject IOptions<MicrosoftAuthSettings> MicrosoftSettings

@{
    var googleEnabled = GoogleSettings.Value.IsEnabled;
    var microsoftEnabled = MicrosoftSettings.Value.IsEnabled;
    var anyEnabled = googleEnabled || microsoftEnabled;
}

@if (anyEnabled)
{
    <div class="sso-divider">
        <hr />
        <span class="sso-divider-text">@DividerText</span>
        <hr />
    </div>

    <div class="sso-buttons">
        @if (googleEnabled)
        {
            <a href="/account/google-login?returnUrl=@Uri.EscapeDataString(ReturnUrl)"
               class="btn btn-sso btn-sso-google"
               aria-label="@ActionVerb with Google">
                <svg class="sso-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                </svg>
                <span>@ActionVerb with Google</span>
            </a>
        }

        @if (microsoftEnabled)
        {
            <a href="/account/microsoft-login?returnUrl=@Uri.EscapeDataString(ReturnUrl)"
               class="btn btn-sso btn-sso-microsoft"
               aria-label="@ActionVerb with Microsoft">
                <svg class="sso-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 23 23">
                    <rect fill="#f35325" x="1" y="1" width="10" height="10"/>
                    <rect fill="#81bc06" x="12" y="1" width="10" height="10"/>
                    <rect fill="#05a6f0" x="1" y="12" width="10" height="10"/>
                    <rect fill="#ffba08" x="12" y="12" width="10" height="10"/>
                </svg>
                <span>@ActionVerb with Microsoft</span>
            </a>
        }
    </div>
}

@code {
    /// <summary>
    /// The URL to return to after successful authentication.
    /// </summary>
    [Parameter]
    public string ReturnUrl { get; set; } = "/";

    /// <summary>
    /// The action verb to display on buttons (e.g., "Sign in", "Sign up").
    /// </summary>
    [Parameter]
    public string ActionVerb { get; set; } = "Sign in";

    /// <summary>
    /// Text shown in the divider between the form and SSO buttons.
    /// </summary>
    [Parameter]
    public string DividerText { get; set; } = "Or continue with";
}
