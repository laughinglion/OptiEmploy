@page "/account/forgot-password"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@layout EmploymentVerify.Web.Components.Layout.MainLayout

<PageTitle>Forgot Password - Employment Verify</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-1">Reset Password</h3>
                    <p class="text-center text-muted mb-4">Enter your email and we'll send you a reset link</p>

                    @if (_submitted)
                    {
                        <div class="alert alert-success" role="alert">
                            <strong>Check your inbox.</strong> If an account with that email exists, a password reset link has been sent. The link expires in 1 hour.
                        </div>
                        <div class="text-center mt-3">
                            <a href="/account/login" class="btn btn-outline-primary">Back to Sign In</a>
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <small>@_errorMessage</small>
                                <button type="button" class="btn-close btn-close-sm" @onclick="() => _errorMessage = null" aria-label="Close"></button>
                            </div>
                        }

                        <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="forgot-password" novalidate>
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label for="email" class="form-label">Email Address</label>
                                <InputText id="email" class="form-control" @bind-Value="_model.Email"
                                           placeholder="you@example.com" autocomplete="email" />
                                <ValidationMessage For="@(() => _model.Email)" />
                            </div>

                            <button type="submit" class="btn btn-primary w-100" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Sending...</span>
                                }
                                else
                                {
                                    <span>Send Reset Link</span>
                                }
                            </button>
                        </EditForm>

                        <div class="text-center mt-3">
                            <a href="/account/login" class="text-decoration-none">Back to Sign In</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordModel _model = new();
    private bool _isSubmitting;
    private bool _submitted;
    private string? _errorMessage;

    private async Task HandleSubmit()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var payload = new { email = _model.Email?.Trim() };
            // Always returns 200 — intentional anti-enumeration design
            await client.PostAsJsonAsync("/api/auth/forgot-password", payload);
            _submitted = true;
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server. Please check your connection and try again.";
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again later.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "A valid email address is required.")]
        public string? Email { get; set; }
    }
}
