{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Pricing": {
    "VerificationCostCredits": 1.00
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=employment_verify;Username=postgres;Password=your_password_here"
  },

  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET_KEY_IN_PRODUCTION_ENVIRONMENT",
    "Issuer": "EmploymentVerify",
    "Audience": "EmploymentVerify",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "Encryption": {
    "FieldKey": "CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_FOR_FIELD_ENCRYPTION"
  },

  "App": {
    "BaseUrl": "https://localhost:5001"
  },

  "AdminSeed": {
    "Email": "",
    "Password": "",
    "FullName": "System Administrator"
  },

  "Serilog": {
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": ""
        }
      }
    ]
  },

  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "your-email@gmail.com",
    "Password": "your-app-password-here",
    "FromAddress": "noreply@yourcompany.co.za",
    "FromName": "Employment Verify",
    "EnableSsl": true
  }
}
