@page "/admin/verifications"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireAdmin)]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>All Verifications - Employment Verify</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">All Verifications</h2>
            <p class="text-muted mb-0">View all verification requests across all requestors.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@_isLoading">
            <span class="bi bi-arrow-clockwise me-1"></span> Refresh
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Filter by Status</label>
                    <select class="form-select" @bind="_statusFilter">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="EmailSent">Email Sent</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Denied">Denied</option>
                        <option value="UnableToVerify">Unable to Verify</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="() => { _page = 1; return LoadAsync(); }">Apply</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Requests</span>
            @if (_items is not null)
            {
                <span class="badge bg-secondary">@_totalCount total</span>
            }
        </div>
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (_items is null || _items.Count == 0)
            {
                <div class="text-center p-5 text-muted">No verifications found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee</th>
                                <th>Company</th>
                                <th>Job Title</th>
                                <th class="text-center">Status</th>
                                <th>Submitted</th>
                                <th>Completed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _items)
                            {
                                <tr>
                                    <td><strong>@v.EmployeeFullName</strong></td>
                                    <td>@v.CompanyName</td>
                                    <td>@v.JobTitle</td>
                                    <td class="text-center">@StatusBadge(v.Status)</td>
                                    <td><small>@v.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></td>
                                    <td>
                                        @if (v.CompletedAt.HasValue)
                                        {
                                            <small>@v.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">—</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (_totalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-3">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page - 1)" disabled="@(_page <= 1)">Previous</button>
                </li>
                @for (var p = 1; p <= _totalPages; p++)
                {
                    var pageNum = p;
                    <li class="page-item @(pageNum == _page ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => GoToPage(_page + 1)" disabled="@(_page >= _totalPages)">Next</button>
                </li>
            </ul>
        </nav>
    }
</div>

@code {
    private List<VerificationItem>? _items;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _statusFilter = string.Empty;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages;
    private const int PageSize = 20;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task GoToPage(int page) { _page = page; await LoadAsync(); }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var qs = $"?page={_page}&pageSize={PageSize}";
            if (!string.IsNullOrEmpty(_statusFilter))
                qs += $"&status={Uri.EscapeDataString(_statusFilter)}";
            var response = await client.GetAsync($"/api/verifications{qs}");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PagedResult>();
                _items = result?.Items ?? new();
                _totalCount = result?.TotalCount ?? 0;
                _totalPages = result?.TotalPages ?? 0;
            }
            else
                _errorMessage = $"Failed to load verifications ({(int)response.StatusCode}).";
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static RenderFragment StatusBadge(string status) => builder =>
    {
        var (css, label) = status switch
        {
            "Pending"        => ("bg-warning text-dark", "Pending"),
            "EmailSent"      => ("bg-primary", "Email Sent"),
            "InProgress"     => ("bg-info text-dark", "In Progress"),
            "Confirmed"      => ("bg-success", "Confirmed"),
            "Denied"         => ("bg-danger", "Denied"),
            "UnableToVerify" => ("bg-secondary", "Unable to Verify"),
            _                => ("bg-secondary", status)
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {css}");
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    private sealed class PagedResult
    {
        public List<VerificationItem> Items { get; set; } = new();
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
    }

    private sealed class VerificationItem
    {
        public Guid Id { get; set; }
        public string EmployeeFullName { get; set; } = string.Empty;
        public string CompanyName { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public DateTime SubmittedAt { get; set; }
        public DateTime? CompletedAt { get; set; }
    }
}
