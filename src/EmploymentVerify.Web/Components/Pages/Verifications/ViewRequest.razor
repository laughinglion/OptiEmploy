@page "/verifications/{Id:guid}"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireAdminOrRequestor)]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>Verification Details - Employment Verify</PageTitle>

<div class="container mt-4">
    <div class="mb-3">
        <a href="/verifications/my-requests" class="text-decoration-none">
            <span class="bi bi-arrow-left me-1" aria-hidden="true"></span>Back to My Requests
        </a>
    </div>

    @if (_isLoading)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mt-2">Loading verification details...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">@_errorMessage</div>
    }
    else if (_detail is not null)
    {
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h2 class="mb-1">@_detail.EmployeeFullName</h2>
                <p class="text-muted mb-0">@_detail.CompanyName &mdash; @_detail.JobTitle</p>
            </div>
            <span class="badge @StatusBadgeCss(_detail.Status) fs-6">@StatusLabel(_detail.Status)</span>
        </div>

        <div class="row g-4">
            @* ── Employment details ── *@
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header">Employment Details</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Employee</dt>
                            <dd class="col-sm-7">@_detail.EmployeeFullName</dd>
                            <dt class="col-sm-5">ID Number</dt>
                            <dd class="col-sm-7"><code>@_detail.EmployeeIdNumber</code></dd>
                            <dt class="col-sm-5">Company</dt>
                            <dd class="col-sm-7">@_detail.CompanyName</dd>
                            <dt class="col-sm-5">Job Title</dt>
                            <dd class="col-sm-7">@_detail.JobTitle</dd>
                            <dt class="col-sm-5">Start Date</dt>
                            <dd class="col-sm-7">@_detail.EmploymentStartDate.ToString("dd MMM yyyy")</dd>
                            <dt class="col-sm-5">End Date</dt>
                            <dd class="col-sm-7">
                                @if (_detail.EmploymentEndDate.HasValue)
                                {
                                    @_detail.EmploymentEndDate.Value.ToString("dd MMM yyyy")
                                }
                                else
                                {
                                    <span class="text-success">Currently employed</span>
                                }
                            </dd>
                            <dt class="col-sm-5">Consent Type</dt>
                            <dd class="col-sm-7">@_detail.ConsentType</dd>
                        </dl>
                    </div>
                </div>
            </div>

            @* ── Status & timeline ── *@
            <div class="col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header">Status & Timeline</div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Status</dt>
                            <dd class="col-sm-7"><span class="badge @StatusBadgeCss(_detail.Status)">@StatusLabel(_detail.Status)</span></dd>
                            <dt class="col-sm-5">Method</dt>
                            <dd class="col-sm-7">@(_detail.VerificationMethod ?? "Pending")</dd>
                            <dt class="col-sm-5">Submitted</dt>
                            <dd class="col-sm-7"><small>@_detail.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></dd>
                            <dt class="col-sm-5">Completed</dt>
                            <dd class="col-sm-7">
                                @if (_detail.CompletedAt.HasValue)
                                {
                                    <small>@_detail.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                }
                                else
                                {
                                    <small class="text-muted">In progress</small>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>

            @* ── Response ── *@
            @if (_detail.Response is not null)
            {
                <div class="col-12">
                    <div class="card shadow-sm border-@(_detail.Status == "Confirmed" ? "success" : _detail.Status == "Denied" ? "danger" : "secondary")">
                        <div class="card-header">Verification Response</div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <dl class="row mb-0">
                                        <dt class="col-sm-5">Responded By</dt>
                                        <dd class="col-sm-7">@_detail.Response.RespondedBy</dd>
                                        <dt class="col-sm-5">Outcome</dt>
                                        <dd class="col-sm-7">
                                            <span class="badge @(_detail.Response.ResponseType == "Confirmed" ? "bg-success" : "bg-danger")">
                                                @_detail.Response.ResponseType
                                            </span>
                                        </dd>
                                        <dt class="col-sm-5">Responded At</dt>
                                        <dd class="col-sm-7"><small>@_detail.Response.RespondedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></dd>
                                    </dl>
                                </div>
                                <div class="col-md-6">
                                    <dl class="row mb-0">
                                        @if (!string.IsNullOrEmpty(_detail.Response.ConfirmedJobTitle))
                                        {
                                            <dt class="col-sm-5">Confirmed Title</dt>
                                            <dd class="col-sm-7">@_detail.Response.ConfirmedJobTitle</dd>
                                        }
                                        @if (_detail.Response.ConfirmedStartDate.HasValue)
                                        {
                                            <dt class="col-sm-5">Confirmed Start</dt>
                                            <dd class="col-sm-7">@_detail.Response.ConfirmedStartDate.Value.ToString("dd MMM yyyy")</dd>
                                        }
                                        @if (_detail.Response.ConfirmedEndDate.HasValue)
                                        {
                                            <dt class="col-sm-5">Confirmed End</dt>
                                            <dd class="col-sm-7">@_detail.Response.ConfirmedEndDate.Value.ToString("dd MMM yyyy")</dd>
                                        }
                                        @if (_detail.Response.IsCurrentlyEmployed.HasValue)
                                        {
                                            <dt class="col-sm-5">Currently Employed</dt>
                                            <dd class="col-sm-7">@(_detail.Response.IsCurrentlyEmployed.Value ? "Yes" : "No")</dd>
                                        }
                                        @if (!string.IsNullOrEmpty(_detail.Response.Notes))
                                        {
                                            <dt class="col-sm-5">Notes</dt>
                                            <dd class="col-sm-7">@_detail.Response.Notes</dd>
                                        }
                                    </dl>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── Export button ── *@
            @if (_detail.Status is "Confirmed" or "Denied")
            {
                <div class="col-12">
                    <a href="@($"/api/verifications/{_detail.Id}/export")" target="_blank" class="btn btn-outline-primary">
                        <span class="bi bi-download me-1" aria-hidden="true"></span>Export Certificate
                    </a>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private VerificationDetail? _detail;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.GetAsync($"/api/verifications/{Id}");

            if (response.IsSuccessStatusCode)
            {
                _detail = await response.Content.ReadFromJsonAsync<VerificationDetail>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/account/login");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _errorMessage = "Verification not found or you do not have access.";
            }
            else
            {
                _errorMessage = $"Failed to load verification. Server returned {(int)response.StatusCode}.";
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string StatusBadgeCss(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "EmailSent" => "bg-primary",
        "InProgress" => "bg-warning text-dark",
        "Confirmed" => "bg-success",
        "Denied" => "bg-danger",
        "UnableToVerify" => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string StatusLabel(string status) => status switch
    {
        "EmailSent" => "Email Sent",
        "InProgress" => "In Progress",
        "UnableToVerify" => "Unable to Verify",
        _ => status
    };

    private sealed class VerificationDetail
    {
        public Guid Id { get; set; }
        public Guid RequestorId { get; set; }
        public string EmployeeFullName { get; set; } = string.Empty;
        public string EmployeeIdNumber { get; set; } = string.Empty;
        public string CompanyName { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public DateOnly EmploymentStartDate { get; set; }
        public DateOnly? EmploymentEndDate { get; set; }
        public string Status { get; set; } = string.Empty;
        public string? VerificationMethod { get; set; }
        public string ConsentType { get; set; } = string.Empty;
        public DateTime SubmittedAt { get; set; }
        public DateTime? CompletedAt { get; set; }
        public VerificationResponse? Response { get; set; }
    }

    private sealed class VerificationResponse
    {
        public string RespondedBy { get; set; } = string.Empty;
        public string ResponseType { get; set; } = string.Empty;
        public string? ConfirmedJobTitle { get; set; }
        public DateOnly? ConfirmedStartDate { get; set; }
        public DateOnly? ConfirmedEndDate { get; set; }
        public bool? IsCurrentlyEmployed { get; set; }
        public string? Notes { get; set; }
        public DateTime RespondedAt { get; set; }
    }
}
