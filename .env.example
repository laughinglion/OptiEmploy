# Copy this file to .env and fill in your values
# docker-compose will automatically load .env

# PostgreSQL
POSTGRES_PASSWORD=changeme

# JWT — generate with: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET_KEY_IN_PRODUCTION

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_ADDRESS=noreply@yourcompany.co.za

# Field encryption key for PII at rest (SA ID numbers)
ENCRYPTION_FIELD_KEY=

# Admin seed — creates initial admin on first run (leave blank to skip)
ADMIN_SEED_EMAIL=admin@yourcompany.co.za
ADMIN_SEED_PASSWORD=

# SSO (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
