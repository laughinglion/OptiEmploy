@page "/operations/verifications"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireAdminOrOperator)]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation

<PageTitle>All Verifications - Employment Verify</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">All Verifications</h2>
            <p class="text-muted mb-0">View and manage all verification requests across the system.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="LoadVerificationsAsync" disabled="@_isLoading">
            <span class="bi bi-arrow-clockwise me-1" aria-hidden="true"></span> Refresh
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    @* Filter toolbar *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="statusFilter" class="form-label">Filter by Status</label>
                    <select id="statusFilter" class="form-select" @bind="_statusFilter">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="EmailSent">Email Sent</option>
                        <option value="InProgress">In Progress</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Denied">Denied</option>
                        <option value="UnableToVerify">Unable to Verify</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100" @onclick="LoadVerificationsAsync">
                        Apply Filter
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Verification Requests</span>
            @if (_verifications is not null)
            {
                <span class="badge bg-secondary">@_verifications.Count total</span>
            }
        </div>
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted mt-2">Loading verifications...</p>
                </div>
            }
            else if (_verifications is null || _verifications.Count == 0)
            {
                <div class="text-center p-5">
                    <p class="text-muted mb-0">No verifications found matching the current filter.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Employee Name</th>
                                <th>Company</th>
                                <th>Job Title</th>
                                <th class="text-center">Status</th>
                                <th>Submitted</th>
                                <th>Completed</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in _verifications)
                            {
                                <tr>
                                    <td><strong>@v.EmployeeFullName</strong></td>
                                    <td>@v.CompanyName</td>
                                    <td>@v.JobTitle</td>
                                    <td class="text-center">
                                        @StatusBadgeHtml(v.Status)
                                    </td>
                                    <td><small>@v.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></td>
                                    <td>
                                        @if (v.CompletedAt.HasValue)
                                        {
                                            <small>@v.CompletedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">—</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => ToggleDetails(v.Id)">
                                            @(_expandedId == v.Id ? "Hide Details" : "View Details")
                                        </button>
                                    </td>
                                </tr>
                                @if (_expandedId == v.Id && _detailMap.TryGetValue(v.Id, out var detail))
                                {
                                    <tr class="table-light">
                                        <td colspan="7">
                                            <div class="p-3">
                                                @if (detail is null)
                                                {
                                                    <div class="text-center">
                                                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                                                            <span class="visually-hidden">Loading...</span>
                                                        </div>
                                                        <span class="ms-2 text-muted">Loading details...</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <h6 class="text-muted mb-2">Employment Details</h6>
                                                            <dl class="row mb-0">
                                                                <dt class="col-sm-5">Start Date</dt>
                                                                <dd class="col-sm-7">@detail.EmploymentStartDate.ToString("dd MMM yyyy")</dd>
                                                                <dt class="col-sm-5">End Date</dt>
                                                                <dd class="col-sm-7">
                                                                    @(detail.EmploymentEndDate.HasValue
                                                                        ? detail.EmploymentEndDate.Value.ToString("dd MMM yyyy")
                                                                        : "Currently employed")
                                                                </dd>
                                                                <dt class="col-sm-5">Method</dt>
                                                                <dd class="col-sm-7">@(detail.VerificationMethod ?? "—")</dd>
                                                                <dt class="col-sm-5">Consent Type</dt>
                                                                <dd class="col-sm-7">@detail.ConsentType</dd>
                                                            </dl>
                                                        </div>
                                                        @if (detail.Response is not null)
                                                        {
                                                            <div class="col-md-6">
                                                                <h6 class="text-muted mb-2">Response</h6>
                                                                <dl class="row mb-0">
                                                                    <dt class="col-sm-5">Responded By</dt>
                                                                    <dd class="col-sm-7">@detail.Response.RespondedBy</dd>
                                                                    <dt class="col-sm-5">Outcome</dt>
                                                                    <dd class="col-sm-7">@detail.Response.ResponseType</dd>
                                                                    @if (!string.IsNullOrEmpty(detail.Response.ConfirmedJobTitle))
                                                                    {
                                                                        <dt class="col-sm-5">Confirmed Title</dt>
                                                                        <dd class="col-sm-7">@detail.Response.ConfirmedJobTitle</dd>
                                                                    }
                                                                    @if (!string.IsNullOrEmpty(detail.Response.Notes))
                                                                    {
                                                                        <dt class="col-sm-5">Notes</dt>
                                                                        <dd class="col-sm-7">@detail.Response.Notes</dd>
                                                                    }
                                                                    <dt class="col-sm-5">Responded At</dt>
                                                                    <dd class="col-sm-7"><small>@detail.Response.RespondedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></dd>
                                                                </dl>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<VerificationSummaryItem>? _verifications;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _statusFilter = string.Empty;
    private Guid? _expandedId;
    private Dictionary<Guid, VerificationDetailItem?> _detailMap = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadVerificationsAsync();
    }

    private async Task LoadVerificationsAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var url = "/api/verifications" +
                (!string.IsNullOrEmpty(_statusFilter) ? $"?status={Uri.EscapeDataString(_statusFilter)}" : "");

            var response = await client.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                _verifications = await response.Content.ReadFromJsonAsync<List<VerificationSummaryItem>>() ?? new();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/account/login");
            }
            else
            {
                _errorMessage = $"Failed to load verifications. Server returned {(int)response.StatusCode}.";
                _verifications = new();
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server. Please check your connection and try again.";
            _verifications = new();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ToggleDetails(Guid id)
    {
        if (_expandedId == id)
        {
            _expandedId = null;
            return;
        }

        _expandedId = id;

        if (!_detailMap.ContainsKey(id))
        {
            _detailMap[id] = null;
            StateHasChanged();

            try
            {
                var client = HttpClientFactory.CreateClient("ApiClient");
                var response = await client.GetAsync($"/api/verifications/{id}");

                if (response.IsSuccessStatusCode)
                {
                    _detailMap[id] = await response.Content.ReadFromJsonAsync<VerificationDetailItem>();
                }
                else
                {
                    _detailMap.Remove(id);
                    _errorMessage = "Failed to load verification details.";
                }
            }
            catch
            {
                _detailMap.Remove(id);
                _errorMessage = "Unable to load verification details.";
            }
        }
    }

    // ── Helpers ──

    private static RenderFragment StatusBadgeHtml(string status) => builder =>
    {
        var (cssClass, label) = status switch
        {
            "Pending"         => ("bg-warning text-dark", "Pending"),
            "EmailSent"       => ("bg-primary", "Email Sent"),
            "InProgress"      => ("bg-warning text-dark", "In Progress"),
            "Confirmed"       => ("bg-success", "Confirmed"),
            "Denied"          => ("bg-danger", "Denied"),
            "UnableToVerify"  => ("bg-secondary", "Unable to Verify"),
            _                 => ("bg-secondary", status)
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {cssClass}");
        builder.AddContent(2, label);
        builder.CloseElement();
    };

    // ── Local DTOs ──

    private sealed class VerificationSummaryItem
    {
        public Guid Id { get; set; }
        public string EmployeeFullName { get; set; } = string.Empty;
        public string CompanyName { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public DateTime SubmittedAt { get; set; }
        public DateTime? CompletedAt { get; set; }
    }

    private sealed class VerificationDetailItem
    {
        public Guid Id { get; set; }
        public string EmployeeFullName { get; set; } = string.Empty;
        public string CompanyName { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public DateOnly EmploymentStartDate { get; set; }
        public DateOnly? EmploymentEndDate { get; set; }
        public string Status { get; set; } = string.Empty;
        public string? VerificationMethod { get; set; }
        public string ConsentType { get; set; } = string.Empty;
        public DateTime SubmittedAt { get; set; }
        public DateTime? CompletedAt { get; set; }
        public VerificationResponseItem? Response { get; set; }
    }

    private sealed class VerificationResponseItem
    {
        public string RespondedBy { get; set; } = string.Empty;
        public string ResponseType { get; set; } = string.Empty;
        public string? ConfirmedJobTitle { get; set; }
        public DateOnly? ConfirmedStartDate { get; set; }
        public DateOnly? ConfirmedEndDate { get; set; }
        public bool? IsCurrentlyEmployed { get; set; }
        public string? Notes { get; set; }
        public DateTime RespondedAt { get; set; }
    }
}
