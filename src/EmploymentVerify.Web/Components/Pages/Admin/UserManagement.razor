@page "/admin/users"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireAdmin)]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>User Management - Employment Verify</PageTitle>

<div class="container-fluid mt-4">
    <h2 class="mb-1">User Management</h2>
    <p class="text-muted mb-4">Manage user accounts, assign roles, and control access to the platform.</p>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
        </div>
    }

    <div class="row g-4 mb-4">

        @* ── Create New User Card ── *@
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-secondary text-white">
                    <strong>Create New User</strong>
                </div>
                <div class="card-body">
                    @if (_registerFormErrors.Count > 0)
                    {
                        <div class="alert alert-danger py-2">
                            <ul class="mb-0">@foreach (var err in _registerFormErrors) { <li>@err</li> }</ul>
                        </div>
                    }
                    <div class="mb-2">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" placeholder="user@example.com" @bind="_registerForm.Email" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_registerForm.FullName" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" placeholder="Min 8 characters" @bind="_registerForm.Password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="form-select" @bind="_registerForm.Role">
                            <option value="">— No role (assign later) —</option>
                            <option value="Admin">Admin</option>
                            <option value="Requestor">Requestor</option>
                            <option value="Operator">Operator</option>
                        </select>
                    </div>
                    <button class="btn btn-secondary w-100" @onclick="RegisterUserAsync" disabled="@_isRegistering">
                        @if (_isRegistering) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create User
                    </button>
                </div>
            </div>
        </div>

        @* ── Assign Role Card ── *@
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <strong>Assign Role</strong>
                </div>
                <div class="card-body">
                    @if (_roleFormErrors.Count > 0)
                    {
                        <div class="alert alert-danger py-2">
                            <ul class="mb-0">@foreach (var err in _roleFormErrors) { <li>@err</li> }</ul>
                        </div>
                    }
                    <div class="mb-2">
                        <label class="form-label">User ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" placeholder="xxxxxxxx-xxxx-..." @bind="_roleForm.UserId" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_roleForm.Role">
                            <option value="">— Select a role —</option>
                            <option value="Admin">Admin</option>
                            <option value="Requestor">Requestor</option>
                            <option value="Operator">Operator</option>
                        </select>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="AssignRoleAsync" disabled="@_isAssigningRole">
                        @if (_isAssigningRole) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Assign Role
                    </button>
                </div>
            </div>
        </div>

        @* ── Add Credits Card ── *@
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <strong>Add Credits</strong>
                </div>
                <div class="card-body">
                    @if (_creditsFormErrors.Count > 0)
                    {
                        <div class="alert alert-danger py-2">
                            <ul class="mb-0">@foreach (var err in _creditsFormErrors) { <li>@err</li> }</ul>
                        </div>
                    }
                    <div class="mb-2">
                        <label class="form-label">User ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control font-monospace" placeholder="xxxxxxxx-xxxx-..." @bind="_creditsForm.UserId" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Amount (credits) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" min="1" step="1" placeholder="e.g. 10" @bind="_creditsForm.Amount" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <input type="text" class="form-control" placeholder="Optional reason" @bind="_creditsForm.Reason" />
                    </div>
                    <button class="btn btn-success w-100" @onclick="AddCreditsAsync" disabled="@_isAddingCredits">
                        @if (_isAddingCredits) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Add Credits
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ── User Listing ── *@
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Registered Users</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadUsersAsync" disabled="@_isLoadingUsers">
                <span class="bi bi-arrow-clockwise me-1"></span> Refresh
            </button>
        </div>
        <div class="card-body p-0">
            @if (_isLoadingUsers)
            {
                <div class="text-center p-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (_users is null || _users.Count == 0)
            {
                <div class="text-center p-4 text-muted">No users found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th class="text-end">Credits</th>
                                <th class="text-center">Status</th>
                                <th>Joined</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _users)
                            {
                                <tr>
                                    <td><strong>@u.FullName</strong></td>
                                    <td><small>@u.Email</small></td>
                                    <td><span class="badge @RoleBadgeClass(u.Role)">@u.Role</span></td>
                                    <td class="text-end"><strong>@u.CreditBalance.ToString("F2")</strong></td>
                                    <td class="text-center">
                                        @if (u.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td><small>@u.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</small></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                @onclick="() => ToggleActiveAsync(u)">
                                            @(u.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string? _errorMessage;
    private string? _successMessage;

    // User listing
    private List<UserItem>? _users;
    private bool _isLoadingUsers = true;

    // Role form
    private RoleFormModel _roleForm = new();
    private List<string> _roleFormErrors = new();
    private bool _isAssigningRole;

    // Register form
    private RegisterFormModel _registerForm = new();
    private List<string> _registerFormErrors = new();
    private bool _isRegistering;

    // Credits form
    private CreditsFormModel _creditsForm = new();
    private List<string> _creditsFormErrors = new();
    private bool _isAddingCredits;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _isLoadingUsers = true;
        StateHasChanged();
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.GetAsync("/api/admin/users");
            if (response.IsSuccessStatusCode)
                _users = await response.Content.ReadFromJsonAsync<List<UserItem>>() ?? new();
            else
                _errorMessage = $"Failed to load users ({(int)response.StatusCode}).";
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server.";
        }
        finally
        {
            _isLoadingUsers = false;
        }
    }

    private async Task ToggleActiveAsync(UserItem user)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.PatchAsJsonAsync($"/api/admin/users/{user.Id}/active", new { isActive = !user.IsActive });
            if (response.IsSuccessStatusCode)
            {
                _successMessage = $"User '{user.Email}' {(!user.IsActive ? "activated" : "deactivated")} successfully.";
                await LoadUsersAsync();
            }
            else
            {
                _errorMessage = $"Failed to update user status ({(int)response.StatusCode}).";
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to connect to the server.";
        }
    }

    private async Task AssignRoleAsync()
    {
        _roleFormErrors.Clear();
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_roleForm.UserId))
            _roleFormErrors.Add("User ID is required.");
        else if (!Guid.TryParse(_roleForm.UserId.Trim(), out _))
            _roleFormErrors.Add("User ID must be a valid GUID.");

        if (string.IsNullOrWhiteSpace(_roleForm.Role))
            _roleFormErrors.Add("Role is required.");

        if (_roleFormErrors.Count > 0) return;

        _isAssigningRole = true;
        try
        {
            var userId = Guid.Parse(_roleForm.UserId.Trim());
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.PutAsJsonAsync($"/api/admin/users/{userId}/role", new { role = _roleForm.Role });

            if (response.IsSuccessStatusCode)
            {
                _successMessage = $"Role '{_roleForm.Role}' assigned to user {userId}.";
                _roleForm = new();
                await LoadUsersAsync();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                _roleFormErrors.Add("User not found.");
            else
                _roleFormErrors.Add($"Server error ({(int)response.StatusCode}).");
        }
        catch (HttpRequestException)
        {
            _roleFormErrors.Add("Unable to connect to the server.");
        }
        finally
        {
            _isAssigningRole = false;
        }
    }

    private async Task RegisterUserAsync()
    {
        _registerFormErrors.Clear();
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_registerForm.Email)) _registerFormErrors.Add("Email is required.");
        if (string.IsNullOrWhiteSpace(_registerForm.FullName)) _registerFormErrors.Add("Full name is required.");
        if (string.IsNullOrWhiteSpace(_registerForm.Password)) _registerFormErrors.Add("Password is required.");
        else if (_registerForm.Password.Length < 8) _registerFormErrors.Add("Password must be at least 8 characters.");

        if (_registerFormErrors.Count > 0) return;

        _isRegistering = true;
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var payload = new
            {
                email = _registerForm.Email.Trim(),
                password = _registerForm.Password,
                fullName = _registerForm.FullName.Trim(),
                companyName = (string?)null,
                role = string.IsNullOrWhiteSpace(_registerForm.Role) ? (string?)null : _registerForm.Role
            };

            var response = await client.PostAsJsonAsync("/api/auth/register", payload);

            if (response.IsSuccessStatusCode || response.StatusCode == System.Net.HttpStatusCode.Created)
            {
                _successMessage = $"User '{_registerForm.Email}' created. Verification email sent.";
                _registerForm = new();
                await LoadUsersAsync();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
                _registerFormErrors.Add("A user with this email already exists.");
            else
                _registerFormErrors.Add($"Server error ({(int)response.StatusCode}).");
        }
        catch (HttpRequestException)
        {
            _registerFormErrors.Add("Unable to connect to the server.");
        }
        finally
        {
            _isRegistering = false;
        }
    }

    private async Task AddCreditsAsync()
    {
        _creditsFormErrors.Clear();
        _successMessage = null;

        if (string.IsNullOrWhiteSpace(_creditsForm.UserId))
            _creditsFormErrors.Add("User ID is required.");
        else if (!Guid.TryParse(_creditsForm.UserId.Trim(), out _))
            _creditsFormErrors.Add("User ID must be a valid GUID.");

        if (_creditsForm.Amount <= 0)
            _creditsFormErrors.Add("Amount must be greater than zero.");

        if (_creditsFormErrors.Count > 0) return;

        _isAddingCredits = true;
        try
        {
            var userId = Guid.Parse(_creditsForm.UserId.Trim());
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.PostAsJsonAsync($"/api/admin/users/{userId}/credits",
                new { amount = _creditsForm.Amount, reason = _creditsForm.Reason });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CreditResult>();
                _successMessage = $"Added {_creditsForm.Amount} credits. New balance: {result?.NewBalance:F2}";
                _creditsForm = new();
                await LoadUsersAsync();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                _creditsFormErrors.Add("User not found.");
            else
                _creditsFormErrors.Add($"Server error ({(int)response.StatusCode}).");
        }
        catch (HttpRequestException)
        {
            _creditsFormErrors.Add("Unable to connect to the server.");
        }
        finally
        {
            _isAddingCredits = false;
        }
    }

    private static string RoleBadgeClass(string role) => role switch
    {
        "Admin" => "bg-danger",
        "Operator" => "bg-warning text-dark",
        _ => "bg-primary"
    };

    // ── Models ──

    private sealed class UserItem
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public string? CompanyName { get; set; }
        public decimal CreditBalance { get; set; }
        public bool IsActive { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    private sealed class CreditResult
    {
        public Guid UserId { get; set; }
        public decimal NewBalance { get; set; }
    }

    private sealed class RoleFormModel
    {
        public string UserId { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
    }

    private sealed class RegisterFormModel
    {
        public string Email { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
    }

    private sealed class CreditsFormModel
    {
        public string UserId { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public string? Reason { get; set; }
    }
}
